{
  "name": "@rockbox-zig/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Rockbox — GraphQL API client with subscriptions and plugin system",
  "module": "src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --minify && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "rockbox",
    "graphql",
    "audio",
    "music-player",
    "sdk",
    "mpd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsirysndr/rockbox-zig.git",
    "directory": "sdk/typescript"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "graphql-ws": "^6.0.8"
  }
}
