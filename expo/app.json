{
  "expo": {
    "name": "Rockbox",
    "slug": "Rockbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rockbox",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tsirysndr.Rockbox"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffc001",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tsirysndr.Rockbox",
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_AUDIO",
        "MANAGE_EXTERNAL_STORAGE",
        "SYSTEM_ALERT_WINDOW",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "WAKE_LOCK",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/SpaceGrotesk.ttf",
            "./assets/fonts/JetBrainsMono.ttf",
            "./assets/fonts/RockfordSans-Light.otf",
            "./assets/fonts/RockfordSans-Regular.otf",
            "./assets/fonts/RockfordSans-RegularItalic.otf",
            "./assets/fonts/RockfordSans-Medium.otf",
            "./assets/fonts/RockfordSans-Bold.otf",
            "./assets/fonts/RockfordSans-BoldItalic.otf",
            "./assets/fonts/RockfordSans-ExtraBold.otf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
